# NaviKarier Backend — environment variables
# Copy to .env and fill in real values. Never commit .env.

# Database (SQLite default for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./navikarier.db
# DATABASE_URL=postgresql://user:password@host:5432/navikarier

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000

# AI-powered CV analysis (set key to enable, otherwise uses hardcoded analysis)
ANTHROPIC_API_KEY=

# App
APP_ENV=development
LOG_LEVEL=info
