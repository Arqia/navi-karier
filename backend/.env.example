# NaviKarier Backend — environment variables
# Copy to .env and fill in real values. Never commit .env.

# Database (SQLite default for local dev)
DATABASE_URL=sqlite:///./navikarier.db

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000

# LLM / AI provider keys (optional — only needed for AI features)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# App
APP_ENV=development
LOG_LEVEL=info
